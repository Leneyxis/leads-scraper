# LinkedIn (required for authenticated search)
# Option A — Direct cookie (easiest): paste li_at from browser DevTools → Application → Cookies
LINKEDIN_LI_AT=
# Option B — Full JSON: [{"name":"li_at","value":"..."}]
# LINKEDIN_COOKIES=
# Option C — Email/password (may trigger CAPTCHA)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_HEADLESS=true

# Optional: LINKEDIN_HEADLESS=false for visible browser (debugging)
# Optional: residential proxy to avoid ERR_TOO_MANY_REDIRECTS from datacenter IPs
# LINKEDIN_PROXY=http://user:pass@proxy.example.com:8080

# Reddit PRAW (REQUIRED for Reddit scraping)
# Create "installed app" at https://www.reddit.com/prefs/apps (script apps may be blocked)
REDDIT_CLIENT_ID=your_client_id
# Optional: for script app; leave empty for installed app
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Rate limit: seconds between requests (default 2.5)
REDDIT_RATE_LIMIT_DELAY=2.5

# Proxies — required on many VPS/datacenters (Reddit often blocks or blackholes those IPs → connect timeout)
# Single: REDDIT_PROXY=http://user:pass@host:port
# Rotate: REDDIT_PROXY_LIST=http://p1:port,http://p2:port
REDDIT_PROXY=
REDDIT_PROXY_LIST=
# Optional timeouts (seconds): REDDIT_CONNECT_TIMEOUT=30  REDDIT_READ_TIMEOUT=90
# TLS: curl-cffi impersonates Chrome (default chrome124). Disable: REDDIT_TLS_IMPERSONATE=
# If Reddit still returns 403 from your VPS, use a residential REDDIT_PROXY.

# Cloudflare Tunnel (optional — for cloudflared container)
# Create tunnel at Zero Trust dashboard, copy the token
# CLOUDFLARE_TUNNEL_TOKEN=
