# LinkedIn (required for authenticated search)
# Option A — Direct cookie (easiest): paste li_at from browser DevTools → Application → Cookies
LINKEDIN_LI_AT=
# Option B — Full JSON: [{"name":"li_at","value":"..."}]
# LINKEDIN_COOKIES=
# Option C — Email/password (may trigger CAPTCHA)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_HEADLESS=true

# Optional: LINKEDIN_HEADLESS=false for visible browser (debugging)

# Reddit PRAW (REQUIRED for Reddit scraping)
# Create "installed app" at https://www.reddit.com/prefs/apps (script apps may be blocked)
REDDIT_CLIENT_ID=your_client_id
# Optional: for script app; leave empty for installed app
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Rate limit: seconds between requests (default 2.5)
REDDIT_RATE_LIMIT_DELAY=2.5

# Proxies for IP rotation (avoids rate limits)
# Single proxy or rotating service: REDDIT_PROXY=http://user:pass@host:port
# Multiple proxies (rotate per strategy): REDDIT_PROXY_LIST=http://p1:port,http://p2:port
REDDIT_PROXY=
REDDIT_PROXY_LIST=
